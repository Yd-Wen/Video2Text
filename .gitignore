# =============================================================================
# Video2Text (V2T) - Git忽略文件
# 说明: 以下文件/目录不会被Git跟踪，保持仓库干净
# 参考: https://git-scm.com/docs/gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python - 运行时生成的文件
# -----------------------------------------------------------------------------

# Python字节码缓存目录
# 由Python解释器自动生成，无需提交
__pycache__/

# Python字节码文件
# .pyc是.py的字节编译版本，.pyo是优化后的字节码
*.py[cod]

# CPython扩展模块（C/C++编译结果）
*.so
*.pyd
*.dll

# Python包分发目录
# 由python setup.py build/dist生成
build/
dist/
*.egg-info/
.eggs/

# -----------------------------------------------------------------------------
# 虚拟环境 - 开发环境隔离
# -----------------------------------------------------------------------------

# 虚拟环境目录名称（常见命名）
# 这些目录包含完整的Python环境，体积大且环境相关，不应提交
venv/
env/
ENV/
.venv/
.virtualenv/

# -----------------------------------------------------------------------------
# 项目特定 - V2T生成的文件
# -----------------------------------------------------------------------------

# 默认输出目录 - 转录结果
# 用户生成的转录文件不应提交到版本控制
output/

# 临时音频文件目录
# 程序运行时的中间音频文件（即使保留临时文件也不应提交）
temp/
tmp/
*.wav
*.mp3
*.aac
*.ogg
*.m4a

# 日志文件
# 运行时生成的日志
*.log
logs/

# Whisper模型缓存（通常存于用户目录，但以防万一）
# 模型文件体积巨大（tiny: 39MB, base: 74MB, small: 244MB, medium: 769MB, large: 1550MB）
models/
*.pt
*.bin
*.ckpt

# -----------------------------------------------------------------------------
# IDE和编辑器 - 开发环境配置
# -----------------------------------------------------------------------------

# VS Code配置
# 包含个人设置、调试配置、扩展列表等
.vscode/

# PyCharm / IntelliJ IDEA
# 项目配置、索引缓存、运行配置等
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim/Neovim
# 交换文件、备份文件
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
\.#*

# -----------------------------------------------------------------------------
# 操作系统 - 系统自动生成文件
# -----------------------------------------------------------------------------

# macOS
# Finder目录属性文件，存储图标位置、视图设置等
.DS_Store
.AppleDouble
.LSOverride

# Windows
# Windows缩略图缓存（图片预览）
Thumbs.db
# 桌面配置文件
Desktop.ini
# Windows搜索索引
ehthumbs.db

# Linux
# KDE目录属性
.directory

# -----------------------------------------------------------------------------
# 测试和覆盖率报告
# -----------------------------------------------------------------------------

# pytest缓存和报告
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy类型检查缓存
.mypy_cache/
.dmypy.json

# -----------------------------------------------------------------------------
# 环境配置文件（可能包含敏感信息）
# -----------------------------------------------------------------------------

# 环境变量文件
# 通常包含API密钥、数据库密码等敏感配置
.env
.env.local
.env.*.local

# 密钥文件
*.pem
*.key
secrets.json
